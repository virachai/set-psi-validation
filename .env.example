# =============================================================================
# PSI Validation Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables listed here are consumed by scripts in scripts/python/
# and .github/workflows/intraday-pipeline.yml
# =============================================================================

# --- PSI Engine API (Prediction Capture) ---
# Used by: predictions_loader.py
PSI_API_URL=https://api.psi-engine.dev/v1/predict
PSI_ENGINE_API_KEY=sk-your-psi-engine-api-key

# --- SET Market Data API (ATO/ATC Capture) ---
# Used by: capture_market.py
SET_MARKET_API_KEY=sk-your-market-data-api-key
SET_ATO_PRICE=1450.20
SET_ATC_PRICE=1438.10
SET_VOLATILITY=1.95
